{
  "name": "archguard-gateway",
  "main": "src/index.js",
  "compatibility_date": "2026-07-03",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  },
  "queues": {
    "producers": [
      {
        "binding": "ARCHGUARD_QUEUE",
        "queue": "archguard-queue"
      }
    ],
    "consumers": [
      {
        "queue": "archguard-queue",
        "max_batch_size": 1,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  },
  "kv_namespaces": [
    {
      "binding": "RATE_LIMIT_KV",
      "id": "9c8f295b39704d78a0c0220df1014ee2"
    }
  ],
  "vars": {
    "LOCAL_DEV": "true"
  }
}